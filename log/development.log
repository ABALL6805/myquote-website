  <!-- Hidden field for user_id -->
  <%= f.hidden_field :user_id, value: current_user.id %>

  <!-- Form fields associated with the quotes table -->
  <%= f.fields_for :author do |author_fields| %>    <!-- Copilot code - How do I create fields for a the author model in a quote form?-->
  <div class="form-group" style="padding-bottom: 10px;">
    <%= author_fields.text_field :fname, placeholder: 'Author First Name -- REQUIRED', class: 'form-control', required: true %>
  </div>
  <div class="form-group" style="padding-bottom: 10px;">
    <%= author_fields.text_field :lname, placeholder: 'Author Last Name (Optional)', class: 'form-control' %>
  </div>
  <div class="form-group" style="padding-bottom: 10px;">
    <%= author_fields.text_field :birth_year, placeholder: 'Author Birth Year (Optional)', class: 'form-control' %>
  </div>
  <div class="form-group" style="padding-bottom: 40px;">
    <%= author_fields.text_field :death_year, placeholder: 'Author Death Year (Optional)', class: 'form-control' %>
  </div>
<% end %>

  <div class="form-group" style="padding-bottom: 10px;">
    <%= f.text_area :quote, placeholder: 'Quote', class: 'form-control', required: true %>
  </div>

  <div class="form-group" style="padding-bottom: 10px;">
    <%= f.text_field :pub_year, placeholder: 'Year Published (Optional)', class: 'form-control' %>
    <%= f.check_box, class: "form-check-input" %>
  </div>

  <div class="form-group" style="padding-bottom: 10px;">
    <%= f.text_area :comment, placeholder: 'Comment (Optional)', class: 'form-control' %>
  </div>

  <div class="form-check" style="padding-bottom: 10px;">
    <%= f.label :is_public do %>
    Public
    <%= f.check_box :is_visible, class: "form-check-input" %>
    <% end %>
  </div>

  <div id="categories-container">
    <% @quote.category_quotes.each do |category_quote| %>
      <%= f.fields_for :category_quotes, category_quote do |ri| %>
        <div class="category-field row mb-2">
          <div class="col-auto">
            <%= ri.label :category_id, "Category", class: "form-label d-inline-block me-2" %>
            <%= ri.select :category_id, Category.all.collect { |cat| [cat.name, cat.id] }, { include_blank: true }, class: "form-control d-inline-block" %>
          </div>

          <div class="col-auto align-self-end">
            <%= link_to '[-] Remove this category', '#', class: 'remove-category', style: "color: red; text-decoration: none;" %> <!-- Allow users to remove a field -->
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="mt-3">
    <%= f.submit 'Create Quote', class: 'btn btn-primary btn-lg' %>
  </div>
<% end %>

<script>
// Wait for the document to be fully loaded
document.addEventListener('DOMContentLoaded', function() {
  // Attach an event listener to detect clicks on the "Remove this category" link
  document.addEventListener('click', function(e) {
    if (e.target && e.target.classList.contains('remove-category')) {
      // Prevent the default action of the link
      e.preventDefault();

      // Get all the ingredient fields
      const categoryFields = document.querySelectorAll('.category-field');
      // Only remove an ingredient field if there's more than one
      if (categoryFields.length > 1) {
        e.target.closest('.category-field').remove();
      }
    }
  });
});
</script>
