<h1>Welcome to MyQuote!</h1>
<p>Quote your favourite philosophers, authors and more!!!</p>

<h3>Recently Added Quotes</h3>
<hr />
<% @quotes.each do |quote| %>
    <div class="card bg-body-tertiary" style="margin-bottom:10px">
    <div class="card-body">
        <h4 class="card-title"><%= [quote.author.fname, quote.author.lname].compact.join(' ') %></h4>       <!-- copilot code - How do I access the the name of an author through the foreign key?-->
        <p class="card-text"><%= quote.quote %><br />[<a href="/quotes/<%= quote.id %>">Read full quote</a>]</p>
    </div>
    </div>
<% end %>
