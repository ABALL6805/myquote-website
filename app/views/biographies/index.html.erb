<p style="color: green"><%= notice %></p>

<% content_for :title, "Biographies" %>

<h1>Biographies</h1>

<div id="biographies">
  <% @biographies.each do |biography| %>
    <%= render biography %>
    <p>
      <%= link_to "Show this biography", biography %>
    </p>
  <% end %>
</div>

<%= link_to "New biography", new_biography_path %>
