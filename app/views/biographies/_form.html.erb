<%= form_with(model: biography) do |form| %>
  <% if biography.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(biography.errors.count, "error") %> prohibited this biography from being saved:</h2>

      <ul>
        <% biography.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :biography, style: "display: block" %>
